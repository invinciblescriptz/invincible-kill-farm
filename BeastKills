-- Persistent Total Kills
local saveFile = "BeastTotalKills_MuscleLegends.dat"

local function loadKills()
	if isfile(saveFile) then
		local success, data = pcall(function()
			return tonumber(readfile(saveFile)) or 0
		end)
		if success then return data end
	end
	return 0
end

local function saveKills(current)
	pcall(function()
		writefile(saveFile, tostring(current))
	end)
end

local kills = loadKills()

local function updateDisplay()
	killsLabel.Text = "Kills: " .. kills
end

-- Kill Detection
local function tryDetectKill(humanoid)
	local char = humanoid.Parent
	if not char or char == player.Character then return end
	
	wait(0.1)
	
	-- Tag check
	local tags = {"creator", "Killer", "LastAttacker", "Attacker", "DamageSource", "Owner", "KillerPlayer"}
	for _, tagName in ipairs(tags) do
		local tag = humanoid:FindFirstChild(tagName) or char:FindFirstChild(tagName)
		if tag and (tag.Value == player or tag.Value == player.Character or tag.Value == player.Name) then
			kills += 1
			updateDisplay()
			saveKills(kills)
			return
		end
	end
	
	-- Aggressive fallback (counts most deaths you cause in Muscle Legends)
	kills += 1
	updateDisplay()
	saveKills(kills)
end

