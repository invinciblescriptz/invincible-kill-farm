    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if hrp then
        hrp.Size = TARGET_HITBOX_SIZE
        hrp.Transparency = 0.7  -- optional: helps you see the big hitbox
    end
end

local function UpdateCharacter()
    local char = LocalPlayer.Character
    if not char then return nil end
    return {
        Character = char,
        Humanoid = char:FindFirstChildOfClass("Humanoid"),
        RightHand = char:FindFirstChild("RightHand") or char:FindFirstChild("Right Arm") or char:FindFirstChild("RightLowerArm"),
        LeftHand  = char:FindFirstChild("LeftHand")  or char:FindFirstChild("Left Arm")  or char:FindFirstChild("LeftLowerArm"),
        Punch = char:FindFirstChild("Punch") or LocalPlayer.Backpack:FindFirstChild("Punch"),
        HRP = char:FindFirstChild("HumanoidRootPart")
    }
end

