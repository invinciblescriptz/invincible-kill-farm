-- Server Hop Function (unchanged)
local function ServerHop()
    local placeId = game.PlaceId
    local myJobId = game.JobId
    for attempt = 1, 6 do
        local success, response = pcall(function()
            return HttpService:JSONDecode(game:HttpGet("https://games.roblox.com/v1/games/" .. placeId .. "/servers/Public?sortOrder=Desc&limit=100"))
        end)
        if success and response and response.data then
            local candidates = {}
            for _, srv in ipairs(response.data) do
                if srv.id ~= myJobId and srv.playing and srv.maxPlayers and srv.playing < srv.maxPlayers and srv.playing >= 8 then
                    local fill = srv.playing / srv.maxPlayers
                    if fill > 0.25 and fill < 0.9 then
                        table.insert(candidates, srv)
                    end
                end
            end
            if #candidates > 0 then
                local target = candidates[math.random(1, #candidates)]
                TeleportService:TeleportToPlaceInstance(placeId, target.id, LocalPlayer)
                return
            end
        end
        task.wait(3 + attempt * 1.5)
    end
    warn("Server hop: No suitable servers found")
end

-- ====================== MAIN LOOP ======================
RunService.Heartbeat:Connect(function()
    if autoServerHop and (os.clock() - LastServerHop) >= serverHopInterval then
        LastServerHop = os.clock()
        task.spawn(ServerHop)
    end

    if autoSetNight and math.floor(os.clock()) % 5 == 0 then
        setNightTime()
    end
    if autoBigHitbox and math.floor(os.clock() * 10) % 3 == 0 then
        setBigHitbox()
    end
    if autoLockPosition then
        if positionLockAlignPos then
            positionLockAlignPos.Position = gymPos
        end
        local data = UpdateCharacter()
        if data and data.HRP and math.floor(os.clock() * 20) % 3 == 0 then
            data.HRP.CFrame = CFrame.new(gymPos) * data.HRP.CFrame.Rotation
        end
    end

    if not autoFarm then return end

    local data = UpdateCharacter()
    if not data or not data.Humanoid or data.Humanoid.Health <= 0 then return end

    if autoEquipPunch then
        if not data.Punch or (data.Character and not data.Character:FindFirstChild("Punch")) then
            StartAutoEquipPunch()
        end
    end

    if autoBadKarma then
        if not badKarmaConnection then
            StartAutoBadKarma()
        end
    else
        StopAutoBadKarma()
    end

    if _G.fastHitActive then
        if not fastHitConnection1 or not fastHitConnection2 then
            StartFastHit()
        end
    end
end)

