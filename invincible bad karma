-- ====================== AUTO EQUIP PUNCH ======================
local equipConnection
local function StartAutoEquipPunch()
    if equipConnection then return end
    equipConnection = task.spawn(function()
        while autoEquipPunch do
            local char = LocalPlayer.Character
            if char then
                local humanoid = char:FindFirstChildOfClass("Humanoid")
                local punchInChar = char:FindFirstChild("Punch")
                local punchInBP = LocalPlayer.Backpack:FindFirstChild("Punch")
                if humanoid and not punchInChar and punchInBP then
                    humanoid:EquipTool(punchInBP)
                end
            end
            task.wait(0.15)
        end
    end)
end

local function StopAutoEquipPunch()
    autoEquipPunch = false
    if equipConnection then
        task.cancel(equipConnection)
        equipConnection = nil
    end
end

-- ====================== FAST HIT ======================
local fastHitConnection1, fastHitConnection2
local function StartFastHit()
    if fastHitConnection1 or fastHitConnection2 then return end
    
    fastHitConnection1 = task.spawn(function()
        while _G.fastHitActive do
            local punch = LocalPlayer.Backpack:FindFirstChild("Punch")
            if punch then
                punch.Parent = LocalPlayer.Character
                if punch:FindFirstChild("attackTime") then
                    punch.attackTime.Value = 0
                end
            end
            task.wait(0.08)
        end
    end)
    
    fastHitConnection2 = task.spawn(function()
        while _G.fastHitActive do
            local punch = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Punch")
            if punch then
                punch:Activate()
            end
            task.wait(0.05)   -- more aggressive
        end
    end)
end

local function StopFastHit()
    _G.fastHitActive = false
    if fastHitConnection1 then task.cancel(fastHitConnection1) fastHitConnection1 = nil end
    if fastHitConnection2 then task.cancel(fastHitConnection2) fastHitConnection2 = nil end
end

-- ====================== AUTO EVIL KARMA KILL (FIXED & IMPROVED) ======================
local badKarmaConnection

local function ShouldKillForEvil(target)
    if not target or target == LocalPlayer then return false end
    
    local char = target.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return false end
    
    -- Look for Good Karma / Light Karma in common places
    local goodKarma = nil
    local evilKarma = 0
    
    local possibleGood = {"goodKarma", "GoodKarma", "good karma", "LightKarma", "lightKarma"}
    local possibleEvil = {"evilKarma", "EvilKarma", "darkKarma", "DarkKarma"}
    
    -- Check player directly and leaderstats
    for _, name in ipairs(possibleGood) do
        if target:FindFirstChild(name) and target[name]:IsA("IntValue") then
            goodKarma = target[name].Value
            break
        end
        local ls = target:FindFirstChild("leaderstats")
        if ls and ls:FindFirstChild(name) then
            goodKarma = ls[name].Value
            break
        end
    end
    
    for _, name in ipairs(possibleEvil) do
        if target:FindFirstChild(name) and target[name]:IsA("IntValue") then
            evilKarma = target[name].Value
            break
        end
        local ls = target:FindFirstChild("leaderstats")
        if ls and ls:FindFirstChild(name) then
            evilKarma = ls[name].Value
            break
        end
    end
    
    -- Kill if they have Good Karma OR are neutral (very low/zero evil)
    if (goodKarma and goodKarma > 0) or (evilKarma < 50) then
        return true
    end
    
    return false
end

