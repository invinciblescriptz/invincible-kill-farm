local function updateEvilKarma()
    local evil = 0
    if player:FindFirstChild("EvilKarma") then
        evil = player.EvilKarma.Value
    elseif player:FindFirstChild("Evil Karma") then
        evil = player["Evil Karma"].Value
    elseif player:FindFirstChild("leaderstats") then
        local ls = player.leaderstats
        if ls:FindFirstChild("EvilKarma") then evil = ls.EvilKarma.Value
        elseif ls:FindFirstChild("Evil Karma") then evil = ls["Evil Karma"].Value end
    end

    local formatted = evil
    if evil >= 1000000 then
        formatted = string.format("%.1fM", evil / 1000000)
    elseif evil >= 10000 then
        formatted = string.format("%.1fK", evil / 1000)
    end
    karmaLabel.Text = "Evil Karma: " .. formatted
end

