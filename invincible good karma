updateKills()

if LocalPlayer:FindFirstChild("leaderstats") then
    for _, stat in pairs(LocalPlayer.leaderstats:GetChildren()) do
        if stat.Name:lower() == "kills" then
            stat.Changed:Connect(updateKills)
        end
    end
end

