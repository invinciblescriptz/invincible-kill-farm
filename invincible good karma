-- ====================== FRIEND WHITELIST ======================
local function updateFriendWhitelist()
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and LocalPlayer:IsFriendsWith(plr.UserId) then
            playerWhitelist[plr.UserId] = true
        end
    end
end

updateFriendWhitelist()
Players.PlayerAdded:Connect(function(plr)
    if friendWhitelistActive and LocalPlayer:IsFriendsWith(plr.UserId) then
        playerWhitelist[plr.UserId] = true
    end
end)

-- ====================== FAST AUTO PUNCH ======================
_G.fastHitActive = autoFastPunch

local function startFastPunch()
    -- Equip + attackTime loop
    task.spawn(function()
        while _G.fastHitActive do
            local char = LocalPlayer.Character
            if char then
                local punch = LocalPlayer.Backpack:FindFirstChild("Punch")
                if punch then
                    punch.Parent = char
                end
                
                local equippedPunch = char:FindFirstChild("Punch")
                if equippedPunch and equippedPunch:FindFirstChild("attackTime") then
                    equippedPunch.attackTime.Value = 0
                end
            end
            task.wait(0.08)
        end
    end)

    -- Activation spam loop
    task.spawn(function()
        while _G.fastHitActive do
            local char = LocalPlayer.Character
            local punch = char and char:FindFirstChild("Punch")
            if punch then
                punch:Activate()
            end
            task.wait(0.1)
        end
    end)
end

-- Toggle function (you can call this from Killer UI or manually)
local function toggleFastPunch(state)
    _G.fastHitActive = state
    if state then
        startFastPunch()
    else
        local char = LocalPlayer.Character
        local punch = char and char:FindFirstChild("Punch")
        if punch then
            punch.Parent = LocalPlayer.Backpack
        end
    end
    updateStatus()
end

-- Start if enabled
if autoFastPunch then
    startFastPunch()
end

-- ====================== ANIMATION REMOVAL ======================
local function blockPunchAnimations(humanoid)
    if not humanoid then return end
    for _, track in pairs(humanoid:GetPlayingAnimationTracks()) do
        local animId = track.Animation and track.Animation.AnimationId
        local name = track.Name:lower()
        if animId == "rbxassetid://3638729053" or 
           animId == "rbxassetid://3638767427" or
           name:match("punch") or name:match("attack") or name:match("right") then
            track:Stop()
        end
    end
end

local function setupAnimationBlocking()
    local char = LocalPlayer.Character
    if not char then return end
    local humanoid = char:WaitForChild("Humanoid", 3)
    if not humanoid then return end

    blockPunchAnimations(humanoid)
    
    if not _G.AnimBlockConn then
        _G.AnimBlockConn = humanoid.AnimationPlayed:Connect(function()
            task.defer(blockPunchAnimations, humanoid)
        end)
    end
end

-- ====================== AUTO GOOD KARMA ======================
task.spawn(function()
    while autoGoodKarma do
        local char = LocalPlayer.Character
        if char then
            local rightHand = char:FindFirstChild("RightHand")
            local leftHand = char:FindFirstChild("LeftHand")
            
            if rightHand and leftHand then
                for _, target in ipairs(Players:GetPlayers()) do
                    if target == LocalPlayer or (friendWhitelistActive and playerWhitelist[target.UserId]) then
                        continue
                    end
                    
                    local evil = target:FindFirstChild("evilKarma")
                    local good = target:FindFirstChild("goodKarma")
                    
                    if evil and good and evil:IsA("IntValue") and good:IsA("IntValue") and evil.Value > good.Value then
                        local root = target.Character and target.Character:FindFirstChild("HumanoidRootPart")
                        if root then
                            firetouchinterest(rightHand, root, 0)
                            firetouchinterest(leftHand, root, 0)
                            task.wait(0.01)
                            firetouchinterest(rightHand, root, 1)
                            firetouchinterest(leftHand, root, 1)
                        end
                    end
                end
            end
        end
        task.wait(0.1)
    end
end)

