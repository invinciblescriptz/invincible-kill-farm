    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") and (
            obj.Name:lower():find("muscle king") or 
            obj.Name:lower():find("king gym") or 
            obj.Name:lower():find("kingportal") or
            obj.Name == "Muscle King Gym Portal"
        ) then
            HRP.CFrame = obj.CFrame * CFrame.new(0, 5, 0)
            task.wait(0.5)
            firetouchinterest(HRP, obj, 0)
