-- Server Hop (prefers populated)
local function ServerHop()
    local placeId = game.PlaceId
    local jobId   = game.JobId
    local url = "https://games.roblox.com/v1/games/" .. placeId .. "/servers/Public?sortOrder=Desc&limit=100"
    
    local success, data = pcall(HttpService.JSONDecode, HttpService, game:HttpGet(url))
    
    if not success or not data or not data.data then return end
    
    for _, srv in ipairs(data.data) do
        local fill = srv.playing / srv.maxPlayers
        if srv.id ~= jobId and srv.playing >= 12 and fill >= 0.55 then
            TeleportService:TeleportToPlaceInstance(placeId, srv.id, LocalPlayer)
            return
        end
    end
end

