-- Position Lock Vars
local positionLockAlignPos, positionLockAttachment

local function clearPositionLock()
    if positionLockAlignPos then
        positionLockAlignPos:Destroy()
        positionLockAlignPos = nil
    end
    if positionLockAttachment then
        positionLockAttachment:Destroy()
        positionLockAttachment = nil
    end
end

local function setupPositionLock()
    clearPositionLock()
    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    positionLockAttachment = Instance.new("Attachment")
    positionLockAttachment.Parent = hrp
    
    positionLockAlignPos = Instance.new("AlignPosition")
    positionLockAlignPos.Attachment0 = positionLockAttachment
    positionLockAlignPos.Position = gymPos
    positionLockAlignPos.MaxForce = 40000
    positionLockAlignPos.MaxVelocity = math.huge
    positionLockAlignPos.Responsiveness = 200
    positionLockAlignPos.Parent = hrp
end

-- New: Set Night Time Function
local function setNightTime()
    -- Night time: ClockTime 0 = midnight (fully dark)
    -- Use ClockTime for smoother control (0-24 hours)
    Lighting.ClockTime = 0      -- Midnight = complete night
    -- Alternative: Lighting.TimeOfDay = "00:00:00"
    
    -- Optional: Make it even darker if needed (some games override)
    Lighting.Brightness = 0.5
    Lighting.Ambient = Color3.fromRGB(50, 50, 70)     -- Slight blue tint for night feel
    Lighting.OutdoorAmbient = Color3.fromRGB(30, 30, 50)
end

local function GetPlayerStatValue(plr, statNames)
    if not plr then return nil end
    if type(statNames) == "string" then statNames = {statNames} end
    
    for _, name in statNames do
        local val = plr:GetAttribute(name)
        if val ~= nil then return tonumber(val) end
    end
    
    local stats = plr:FindFirstChild("leaderstats")
    if stats then
        for _, name in statNames do
            local v = stats:FindFirstChild(name)
            if v and v:IsA("ValueBase") then return tonumber(v.Value) end
        end
    end
    return nil
end

local function GetLocalPlayerDamage()
    return GetPlayerStatValue(LocalPlayer, {"Damage", "DMG", "Attack", "Strength", "Str"}) or 1
end

local function GetTargetHealth(targetPlayer)
    local hum = targetPlayer.Character and targetPlayer.Character:FindFirstChildOfClass("Humanoid")
    return hum and hum.MaxHealth or 100
end

local function ShouldKillPlayer(targetPlayer)
    if not KillOnlyWeakerEnabled then return true end
    
    local myDmg = GetLocalPlayerDamage()
    local theirHP = GetTargetHealth(targetPlayer)
    local hitsNeeded = math.ceil(theirHP / myDmg)
    
    return hitsNeeded <= 5
end

