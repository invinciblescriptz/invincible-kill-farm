-- Stats
local function GetPlayerStatValue(plr, statNames)
    if not plr then return nil end
    if type(statNames) == "string" then statNames = {statNames} end
    for _, name in statNames do
        local val = plr:GetAttribute(name)
        if val ~= nil then return tonumber(val) end
    end
    local stats = plr:FindFirstChild("leaderstats")
    if stats then
        for _, name in statNames do
            local v = stats:FindFirstChild(name)
            if v and v:IsA("ValueBase") then return tonumber(v.Value) end
        end
    end
    return nil
end

local function GetLocalPlayerDamage()
    return GetPlayerStatValue(LocalPlayer, {"Damage", "DMG", "Attack", "Strength", "Str"}) or 1
end

local function GetTargetHealth(target)
    local hum = target.Character and target.Character:FindFirstChildOfClass("Humanoid")
    return hum and hum.MaxHealth or 100
end

local function ShouldKillPlayer(target)
    if not KillOnlyWeakerEnabled then return true end
    local myDmg = GetLocalPlayerDamage()
    local theirHP = GetTargetHealth(target)
    return math.ceil(theirHP / myDmg) <= 5
end

