local function GetPlayerStatValue(plr, statNames)
    if not plr then return nil end
    if type(statNames) == "string" then statNames = {statNames} end
    for _, name in pairs(statNames) do
        local val = plr:GetAttribute(name)
        if val ~= nil then return tonumber(val) end
    end
    local stats = plr:FindFirstChild("leaderstats")
    if stats then
        for _, name in pairs(statNames) do
            local v = stats:FindFirstChild(name)
            if v and v:IsA("ValueBase") then return tonumber(v.Value) end
        end
    end
    return nil
end

local function GetLocalPlayerDamage()
    return GetPlayerStatValue(LocalPlayer, {"Damage", "DMG", "Attack", "Strength", "Str"}) or 1
end

local function GetTargetHealth(target)
    local hum = target.Character and target.Character:FindFirstChildOfClass("Humanoid")
    return hum and hum.MaxHealth or 100
end

local function ShouldKillPlayer(target)
    if not KillOnlyWeaker then return true end
    local myDmg = GetLocalPlayerDamage()
    local theirHP = GetTargetHealth(target)
    return math.ceil(theirHP / myDmg) <= 5
end

-- Attack function
local LastAttackTime = 0
local function AttackNearbyPlayers()
    if (os.clock() - LastAttackTime) < 0.08 then return end
    LastAttackTime = os.clock()
    local character = LocalPlayer.Character
    if not character then return end
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    local punchTool = character:FindFirstChild("Punch")
    if punchTool then
        punchTool:Activate()
    end

    for _, other in pairs(Players:GetPlayers()) do
        if other ~= LocalPlayer and other.Character then
            if ShouldKillPlayer(other) then
                local targetChar = other.Character
                local head = targetChar:FindFirstChild("Head")
                local root = targetChar:FindFirstChild("HumanoidRootPart")
                local hum = targetChar:FindFirstChildOfClass("Humanoid")
                if head and root and hum and hum.Health > 0 then
                    local wasAnchored = root.Anchored
                    root.Anchored = true
                    firetouchinterest(head, character:FindFirstChild("LeftHand") or character:FindFirstChild("Left Arm"), 0)
                    task.wait()
                    firetouchinterest(head, character:FindFirstChild("LeftHand") or character:FindFirstChild("Left Arm"), 1)
                    root.Anchored = wasAnchored
                end
            end
        end
    end
end

-- Server Hop function
local function ServerHop()
    local placeId = game.PlaceId
    local myJobId = game.JobId
    for attempt=1,6 do
        local success, response = pcall(function()
            return HttpService:JSONDecode(game:HttpGet("https://games.roblox.com/v1/games/"..placeId.."/servers/Public?sortOrder=Desc&limit=100"))
        end)
        if not success or not response or not response.data then wait(2 + attempt) continue end

        local candidates = {}
        for _, srv in pairs(response.data) do
            if srv.id == myJobId then continue end
            if srv.playing >= srv.maxPlayers then continue end
            if srv.playing < 8 then continue end
            local fill = srv.playing / srv.maxPlayers
            if fill > 0.25 and fill < 0.9 then
                table.insert(candidates, srv)
            end
        end

        if #candidates == 0 then wait(3 + attempt*1.5) continue end
        local target = candidates[math.random(1, #candidates)]
        pcall(function()
            TeleportService:TeleportToPlaceInstance(placeId, target.id, LocalPlayer)
        end)
        wait(5 + attempt*2)
    end
end

