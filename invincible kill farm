-- Main heartbeat loop for server hop
RunService.Heartbeat:Connect(function()
    if serverHopActive then
        if os.clock() - lastServerHopTime >= serverHopInterval then
            lastServerHopTime = os.clock()
            serverHop()
        end
    end
end)

