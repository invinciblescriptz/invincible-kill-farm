-- Position Lock
local positionLockAlignPos, positionLockAttachment

local function clearPositionLock()
    if positionLockAlignPos then positionLockAlignPos:Destroy() positionLockAlignPos = nil end
    if positionLockAttachment then positionLockAttachment:Destroy() positionLockAttachment = nil end
end

local function setupPositionLock()
    clearPositionLock()
    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    pcall(function() hrp:SetNetworkOwner(LocalPlayer) end)
    positionLockAttachment = Instance.new("Attachment", hrp)
    positionLockAlignPos = Instance.new("AlignPosition")
    positionLockAlignPos.Attachment0 = positionLockAttachment
    positionLockAlignPos.Position = gymCFrame.Position
    positionLockAlignPos.MaxForce = 1e7
    positionLockAlignPos.MaxVelocity = math.huge
    positionLockAlignPos.Responsiveness = 200
    positionLockAlignPos.RigidityEnabled = true
    positionLockAlignPos.Parent = hrp
end

-- Night Time
local function setNightTime()
    Lighting.ClockTime = 0
    Lighting.Brightness = 0.5
    Lighting.Ambient = Color3.fromRGB(50,50,70)
    Lighting.OutdoorAmbient = Color3.fromRGB(30,30,50)
end

-- Hitbox
local TARGET_HITBOX_SIZE = Vector3.new(25, 25, 25)

local function setBigHitbox()
    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if hrp then hrp.Size = TARGET_HITBOX_SIZE end
end

local function resetHitbox()
    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if hrp then hrp.Size = Vector3.new(2, 2, 1) end
end

-- Stats
local function GetPlayerStatValue(plr, statNames)
    if not plr then return nil end
    if type(statNames) == "string" then statNames = {statNames} end
    for _, name in statNames do
        local val = plr:GetAttribute(name)
        if val ~= nil then return tonumber(val) end
    end
    local stats = plr:FindFirstChild("leaderstats")
    if stats then
        for _, name in statNames do
            local v = stats:FindFirstChild(name)
            if v and v:IsA("ValueBase") then return tonumber(v.Value) end
        end
    end
    return nil
end

local function GetLocalPlayerDamage()
    return GetPlayerStatValue(LocalPlayer, {"Damage", "DMG", "Attack", "Strength", "Str"}) or 1
end

local function GetTargetHealth(target)
    local hum = target.Character and target.Character:FindFirstChildOfClass("Humanoid")
    return hum and hum.MaxHealth or 100
end

local function ShouldKillPlayer(target)
    if not KillOnlyWeakerEnabled then return true end
    local myDmg = GetLocalPlayerDamage()
    local theirHP = GetTargetHealth(target)
    return math.ceil(theirHP / myDmg) <= 5
end

-- Character
local Character, Humanoid, Hand, Punch, HRP
local LastAttack = 0

local function UpdateAll()
