-- // INVINCIBLE PRIVATE KILLING - Auto Kill Counter + Players
-- Paste as LocalScript in StarterPlayerScripts

local player = game.Players.LocalPlayer
local kills = 455036

-- Create GUI
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "InvincibleKillCounter"
screenGui.ResetOnSpawn = false
screenGui.Parent = player:WaitForChild("PlayerGui")

local frame = Instance.new("Frame")
frame.Size = UDim2.new(0, 260, 0, 82)
frame.Position = UDim2.new(0.5, -130, 0, 45)  -- Raised higher
frame.BackgroundColor3 = Color3.fromRGB(17, 17, 17)
frame.BorderSizePixel = 3
frame.BorderColor3 = Color3.fromRGB(45, 45, 45)
frame.Active = true
frame.Draggable = true
frame.Parent = screenGui

-- Corner rounding
local corner = Instance.new("UICorner")
corner.CornerRadius = UDim.new(0, 8)
corner.Parent = frame

local title = Instance.new("TextLabel")
title.Size = UDim2.new(1, 0, 0, 26)
title.BackgroundTransparency = 1
title.Text = "INVINCIBLE PRIVATE KILLING"
title.TextColor3 = Color3.fromRGB(255, 55, 0)
title.TextScaled = true
title.Font = Enum.Font.Code
title.TextStrokeTransparency = 0.6
title.Parent = frame

local killsLabel = Instance.new("TextLabel")
killsLabel.Size = UDim2.new(1, 0, 0, 26)
killsLabel.Position = UDim2.new(0, 0, 0, 28)
killsLabel.BackgroundTransparency = 1
killsLabel.Text = "Kills: " .. kills
killsLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
killsLabel.TextScaled = true
killsLabel.Font = Enum.Font.Code
killsLabel.TextStrokeTransparency = 0.7
killsLabel.Parent = frame

local playersLabel = Instance.new("TextLabel")
playersLabel.Size = UDim2.new(1, 0, 0, 22)
playersLabel.Position = UDim2.new(0, 0, 0, 55)
playersLabel.BackgroundTransparency = 1
playersLabel.Text = "Players: " .. #game.Players:GetPlayers()
playersLabel.TextColor3 = Color3.fromRGB(180, 255, 180)
playersLabel.TextScaled = true
playersLabel.Font = Enum.Font.Code
playersLabel.TextStrokeTransparency = 0.7
playersLabel.Parent = frame

-- Update Kills from leaderstats
local function updateKills()
    local leaderstats = player:FindFirstChild("leaderstats")
    if leaderstats then
        local killsStat = leaderstats:FindFirstChild("Kills") or leaderstats:FindFirstChild("kills")
        if killsStat then
            kills = killsStat.Value
            killsLabel.Text = "Kills: " .. kills
        end
    end
end

player:WaitForChild("leaderstats", 15)
updateKills()

if player:FindFirstChild("leaderstats") then
    local leaderstats = player.leaderstats
    for _, stat in pairs(leaderstats:GetChildren()) do
        if stat.Name:lower() == "kills" then
            stat.Changed:Connect(updateKills)
        end
    end
end

-- Update Players Count
local function updatePlayers()
    playersLabel.Text = "Players: " .. #game.Players:GetPlayers()
end

game.Players.PlayerAdded:Connect(updatePlayers)
game.Players.PlayerRemoving:Connect(updatePlayers)
updatePlayers()

print("✅ INVINCIBLE PRIVATE KILLING Counter Loaded!")
print("Raised higher under top UI")
