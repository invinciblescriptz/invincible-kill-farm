-- Helpers
local function GetStat(plr, names)
    if type(names) == "string" then names = {names} end
    for _, n in names do
        local v = plr:GetAttribute(n) or (plr.leaderstats and plr.leaderstats:FindFirstChild(n) and plr.leaderstats[n].Value)
        if v then return tonumber(v) end
    end
    return 1
end

local function GetLocalDamage()
    return GetStat(LocalPlayer, {"Damage", "DMG", "Attack", "Strength", "Str"})
end

local function ShouldKill(targetPlayer)
    if not KillOnlyWeaker then return true end
    local char = targetPlayer.Character
    if not char then return false end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum or hum.Health <= 0 then return false end
    local hits = math.ceil(hum.MaxHealth / GetLocalDamage())
    return hits <= 5
end

