            color: #ffffff;
            font-size: 38px;
            letter-spacing: 5px;
            text-shadow: 0 0 20px #00ffaa;
            min-width: 170px;
        }
    </style>
</head>
<body>
    <div class="overlay" id="gui">
        <div class="title">INVINCIBLE KILLING</div>
        <div class="kills-container">
            <span class="label">Kills:</span>
            <span id="count" class="counter">000000</span>
        </div>
    </div>

    <script>
        let kills = 0;
        const countEl = document.getElementById('count');
        
        function updateDisplay() {
            countEl.textContent = String(kills).padStart(6, '0');
        }
        
        function addKill() {
            kills++;
            updateDisplay();
            
            // Flash effect like in-game
            const gui = document.getElementById('gui');
            gui.style.boxShadow = '0 0 45px rgba(0, 255, 180, 0.9)';
            setTimeout(() => {
                gui.style.boxShadow = '0 0 30px rgba(255, 40, 40, 0.8)';
            }, 120);
        }
        
        // === Controls ===
        const gui = document.getElementById('gui');
        
        // Click anywhere on the box to +1 kill
        gui.addEventListener('click', addKill);
        
        // Drag the box
        let isDragging = false;
        let currentX = 60, currentY = 60;
        let initialX, initialY;
        
        gui.addEventListener('mousedown', e => {
            isDragging = true;
            initialX = e.clientX - currentX;
            initialY = e.clientY - currentY;
        });
        
        document.addEventListener('mousemove', e => {
            if (isDragging) {
                currentX = e.clientX - initialX;
                currentY = e.clientY - initialY;
                gui.style.left = currentX + 'px';
                gui.style.top = currentY + 'px';
            }
        });
        
        document.addEventListener('mouseup', () => isDragging = false);
        
        // Keyboard: Press K for +1 kill
        document.addEventListener('keydown', e => {
            if (e.key.toLowerCase() === 'k') addKill();
        });
        
        // Load saved kills
        const saved = localStorage.getItem('invincibleKills');
        if (saved) kills = parseInt(saved);
        updateDisplay();
        
        // Auto-save
        setInterval(() => localStorage.setItem('invincibleKills', kills), 2500);
    </script>
</body>
</html>
