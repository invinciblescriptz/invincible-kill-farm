-- Improved ServerHop: Prioritizes low-pop servers with space (fixes "full" issue)
local function ServerHop()
    local placeId = game.PlaceId
    local jobId = game.JobId
    local url = "https://games.roblox.com/v1/games/" .. placeId .. "/servers/Public?sortOrder=Asc&limit=100"  -- Asc for low pop first
    
    local success, data = pcall(function()
        return HttpService:JSONDecode(game:HttpGet(url))
    end)
    
    if not success or not data or not data.data then 
        warn("Server list fetch failed")
        return 
    end
    
    local candidates = {}
    for _, srv in ipairs(data.data) do
        if srv.id ~= jobId 
           and srv.playing < srv.maxPlayers  -- MUST have space
           and srv.playing <= 15              -- Avoid near-full (max 20)
           and srv.playing > 0                -- Skip dead
        then
            table.insert(candidates, srv)
        end
    end
    
    -- Fallback: any with space
    if #candidates == 0 then
        for _, srv in ipairs(data.data) do
            if srv.id ~= jobId and srv.playing < srv.maxPlayers then
                table.insert(candidates, srv)
            end
        end
    end
    
    if #candidates > 0 then
        local chosen = candidates[math.random(1, #candidates)]
        print("Hopping to " .. chosen.playing .. "/" .. chosen.maxPlayers .. " players server")
        TeleportService:TeleportToPlaceInstance(placeId, chosen.id, LocalPlayer)
    else
        warn("No open servers found - retrying later")
    end
end

RunService.Heartbeat:Connect(function()
