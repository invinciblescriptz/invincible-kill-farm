-- Server Hop (improved retry)
local function ServerHop()
    local placeId = game.PlaceId
    local jobId   = game.JobId
    local url = "https://games.roblox.com/v1/games/"..placeId.."/servers/Public?sortOrder=Asc&limit=100"

    local success, data = pcall(HttpService.JSONDecode, HttpService, game:HttpGet(url, true))
    if not success or not data or not data.data then
        task.wait(3) -- retry delay
        return
    end

    local candidates = {}
    for _, srv in data.data do
        if srv.id ~= jobId and srv.playing < srv.maxPlayers and srv.playing <= 14 and srv.playing > 0 then
            table.insert(candidates, srv)
        end
    end

    if #candidates == 0 then
        for _, srv in data.data do
            if srv.id ~= jobId and srv.playing < srv.maxPlayers then
                table.insert(candidates, srv)
            end
        end
    end

    if #candidates > 0 then
        local srv = candidates[math.random(1, #candidates)]
        print("Hopping → " .. srv.playing .. "/" .. srv.maxPlayers)
        TeleportService:TeleportToPlaceInstance(placeId, srv.id, LocalPlayer)
    else
        warn("No good servers → retry soon")
    end
end

