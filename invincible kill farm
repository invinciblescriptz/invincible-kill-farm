        end
        -- Force position occasionally
        if math.floor(os.clock() * 20) % 3 == 0 then
            HRP.CFrame = CFrame.new(gymPos) * HRP.CFrame.Rotation
        end
    end

    -- Update character references
    UpdateAll()

    -- Auto Farm
    if not AutoFarmEnabled or not Character or not Humanoid or Humanoid.Health <= 0 then return end

    -- Equip punch tool if not equipped
    if not Punch then
        local tool = LocalPlayer.Backpack:FindFirstChild("Punch")
        if tool then Humanoid:EquipTool(tool) end
        return
    end

    -- Attack cooldown
    if (os.clock() - LastAttack) < 0.08 then return end
    LastAttack = os.clock()

    -- Attack
    local attackTime = Punch:FindFirstChild("attackTime")
    if attackTime then attackTime.Value = 0 end
    Punch:Activate()

    -- Attack nearby players
    for _, other in ipairs(Players:GetPlayers()) do
        if other == LocalPlayer then continue end
        if not ShouldKillPlayer(other) then continue end

        local char = other.Character
        if not char then continue end

        local hum = char:FindFirstChildOfClass("Humanoid")
        local head = char:FindFirstChild("Head")
        local root = char:FindFirstChild("HumanoidRootPart")

        if hum and head and root and hum.Health > 0 and Hand then
            local wasAnchored = root.Anchored
            root.Anchored = true
            firetouchinterest(head, Hand, 0)
            task.wait()
            firetouchinterest(head, Hand, 1)
            root.Anchored = wasAnchored
        end
    end
end)

