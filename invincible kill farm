-- Walk on Water (VectorForce – more stable 2026)
local buoyancyForce, buoyancyAtt
task.spawn(function()
    if not WalkOnWaterEnabled then return end

    LocalPlayer.CharacterAdded:Connect(function(char)
        local root = char:WaitForChild("HumanoidRootPart", 8)
        local hum  = char:WaitForChild("Humanoid", 8)

        hum:SetStateEnabled(Enum.HumanoidStateType.Swimming, false)

        buoyancyAtt = Instance.new("Attachment")
        buoyancyAtt.Parent = root

        buoyancyForce = Instance.new("VectorForce")
        buoyancyForce.Attachment0 = buoyancyAtt
        buoyancyForce.RelativeTo = Enum.ActuatorRelativeTo.World
        buoyancyForce.Force = Vector3.zero
        buoyancyForce.Parent = root

        local conn
        conn = hum:GetPropertyChangedSignal("FloorMaterial"):Connect(function()
            if hum.FloorMaterial == Enum.Material.Water then
                local mass = root.AssemblyMass
                buoyancyForce.Force = Vector3.new(0, mass * workspace.Gravity * 1.06, 0) -- slight over-buoyancy
            else
                buoyancyForce.Force = Vector3.zero
            end
        end)

        char.AncestryChanged:Connect(function(_, parent)
            if not parent then
                conn:Disconnect()
                if buoyancyForce then buoyancyForce:Destroy() end
                if buoyancyAtt then buoyancyAtt:Destroy() end
            end
        end)
    end)

    if LocalPlayer.Character then
        -- trigger for current char
        local hum = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
        if hum then hum.FloorMaterial = hum.FloorMaterial end
    end
end)

