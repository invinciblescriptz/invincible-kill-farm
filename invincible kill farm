-- Server Hop
local function ServerHop()
    local placeId = game.PlaceId
    local jobId = game.JobId
    
    local success, response = pcall(function()
        return HttpService:JSONDecode(game:HttpGet(
            "https://games.roblox.com/v1/games/" .. placeId .. "/servers/Public?sortOrder=Desc&limit=100"
        ))
    end)
    
    if not success or not response or not response.data then
        warn("Server list fetch failed")
        return
    end
    
    for _, server in ipairs(response.data) do
        if server.id == jobId then continue end
        if server.playing < 10 then continue end
        
        local fill = server.playing / server.maxPlayers
        if fill >= 0.6 then
            TeleportService:TeleportToPlaceInstance(placeId, server.id, LocalPlayer)
            return
        end
    end
    
    warn("No suitable server found")
end

