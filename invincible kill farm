-- Toggle options
local function toggleOption(optionName)
    if optionName == "AutoFarm" then AutoFarm = not AutoFarm
    elseif optionName == "AutoServerHop" then AutoServerHop = not AutoServerHop
    elseif optionName == "AutoLockPosition" then
        AutoLockPosition = not AutoLockPosition
        if not AutoLockPosition then clearPositionLock() end
    elseif optionName == "AutoSetNight" then
        AutoSetNight = not AutoSetNight
    elseif optionName == "AutoBigHitbox" then
        AutoBigHitbox = not AutoBigHitbox
        if not AutoBigHitbox then resetHitbox() end
    end
end

