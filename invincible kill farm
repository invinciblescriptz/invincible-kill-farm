-- Function to teleport to Muscle King Gym
local function TeleportToMuscleKingGym()
    local teleportService = game:GetService("TeleportService")
    local player = game:GetService("Players").LocalPlayer
    teleportService:Teleport(MuscleKingGymPlaceId, player)
end

-- Immediately teleport upon script load
TeleportToMuscleKingGym()

-- Add the teleport button in a new tab
local teleportTab = window:AddTab("Teleport")
teleportTab:AddButton("Go to Muscle King Gym", function()
    TeleportToMuscleKingGym()
end)
