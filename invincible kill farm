local function GetPlayerStatValue(plr, statNames)
    if not plr then return nil end
    if type(statNames) == "string" then statNames = {statNames} end
    for _, name in pairs(statNames) do
        local val = plr:GetAttribute(name)
        if val ~= nil then return tonumber(val) end
    end
    local stats = plr:FindFirstChild("leaderstats")
    if stats then
        for _, name in pairs(statNames) do
            local v = stats:FindFirstChild(name)
            if v and v:IsA("ValueBase") then return tonumber(v.Value) end
        end
    end
    return nil
end

local function GetLocalPlayerDamage()
    return GetPlayerStatValue(LocalPlayer, {"Damage", "DMG", "Attack", "Strength", "Str"}) or 1
end

local function GetTargetHealth(target)
    local hum = target.Character and target.Character:FindFirstChildOfClass("Humanoid")
    return hum and hum.MaxHealth or 100
end

local function ShouldKillPlayer(target)
    if not KillOnlyWeaker then return true end
    local myDmg = GetLocalPlayerDamage()
    local theirHP = GetTargetHealth(target)
    return math.ceil(theirHP / myDmg) <= 5
end

local LastAttackTime = 0
local function AttackNearbyPlayers()
    if (os.clock() - LastAttackTime) < 0.08 then return end
    LastAttackTime = os.clock()
    local char = LocalPlayer.Character
    local punch = char and char:FindFirstChild("Punch")
    if punch then punch:Activate() end
    for _, other in pairs(Players:GetPlayers()) do
        if other ~= LocalPlayer and other.Character then
            if ShouldKillPlayer(other) then
                local c = other.Character
                local head = c:FindFirstChild("Head")
                local root = c:FindFirstChild("HumanoidRootPart")
                local hum = c:FindFirstChildOfClass("Humanoid")
                if head and root and hum and hum.Health > 0 then
                    local wasAnchored = root.Anchored
                    root.Anchored = true
                    firetouchinterest(head, LocalPlayer.Character:FindFirstChild("LeftHand") or LocalPlayer.Character:FindFirstChild("Left Arm"), 0)
                    task.wait()
                    firetouchinterest(head, LocalPlayer.Character:FindFirstChild("LeftHand") or LocalPlayer.Character:FindFirstChild("Left Arm"), 1)
                    root.Anchored = wasAnchored
                end
            end
        end
    end
end

local autoKillRunning = false
local autoKillConnection

local function startAutoKill()
    if autoKillRunning then return end
    autoKillRunning = true
    autoKillConnection = RunService.Heartbeat:Connect(function()
        if not AutoFarm then return end
        local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 then return end
        if not (LocalPlayer.Character:FindFirstChild("Punch")) then
            local tool = LocalPlayer.Backpack:FindFirstChild("Punch")
            if tool then
                local humanoid = hum
                humanoid:EquipTool(tool)
            end
            return
        end
        AttackNearbyPlayers()
    end)
end

local function stopAutoKill()
    if autoKillConnection then autoKillConnection:Disconnect() end
    autoKillRunning = false
end

