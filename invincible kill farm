local killOnlyWeaker = true
local killToggleBtn = createToggle("Kill Only Weaker", yOffset + 480)

-- Variables
local autoFarmActive = false
local autoKillRunning = false
local autoKillConnection
local serverHopActive = false
local lastServerHopTime = os.clock()
local serverHopInterval = tonumber(intervalInput.Text) or 30

-- Functions
local function setNight()
    Lighting.ClockTime = 0
    Lighting.Brightness = 0.5
    Lighting.Ambient = Color3.fromRGB(50, 50, 70)
    Lighting.OutdoorAmbient = Color3.fromRGB(30, 30, 50)
    print("[UI] Night mode activated")
end

local function teleportToGym()
    if HRP then
        HRP.CFrame = CFrame.new(-8625, 17, -5730)
        print("[UI] Teleported to Gym")
    end
end

local function getPlayerDamage()
    local damage = Character:GetAttribute("Damage") or Character:GetAttribute("DMG") or Character:GetAttribute("Attack") or Character:GetAttribute("Strength") or Character:GetAttribute("Str")
    if damage then
        return tonumber(damage)
    end
    local stats = Character:FindFirstChild("leaderstats")
    if stats then
        for _, v in pairs(stats:GetChildren()) do
            if v.Name:lower():find("damage") or v.Name:lower():find("attack") or v.Name:lower():find("str") then
                return tonumber(v.Value)
            end
        end
    end
    return 1
end

local function getTargetHealth(targetPlayer)
    local hum = targetPlayer.Character and targetPlayer.Character:FindFirstChildOfClass("Humanoid")
    if hum then
        return hum.MaxHealth
    end
    return 100
end

local function shouldKill(targetPlayer)
    if not killOnlyWeaker then return true end
    local damage = getPlayerDamage()
    local health = getTargetHealth(targetPlayer)
    return math.ceil(health / damage) <= 5
end

local lastAttackTime = 0
local function attackNearby()
    if os.clock() - lastAttackTime < 0.1 then return end
    lastAttackTime = os.clock()

    local punch = Character:FindFirstChild("Punch")
    if punch then punch:Activate() end

    for _, targetPlayer in pairs(Players:GetPlayers()) do
        if targetPlayer ~= Player and targetPlayer.Character then
            if shouldKill(targetPlayer) then
                local head = targetPlayer.Character:FindFirstChild("Head")
                local root = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
                local hum = targetPlayer.Character:FindFirstChildOfClass("Humanoid")
                if head and root and hum and hum.Health > 0 then
                    local wasAnchored = root.Anchored
                    root.Anchored = true
                    local leftHand = Character:FindFirstChild("LeftHand") or Character:FindFirstChild("Left Arm")
                    if leftHand then
                        firetouchinterest(head, leftHand, 0)
                        task.wait(0.1)
                        firetouchinterest(head, leftHand, 1)
                        root.Anchored = wasAnchored
                    end
                end
            end
        end
    end
end

local function startAutoKill()
    if autoKillRunning then return end
    autoKillRunning = true
    autoKillConnection = RunService.Heartbeat:Connect(function()
        if not autoFarmActive then return end
        local hum = Human
        if hum and hum.Health > 0 then
            if not Character:FindFirstChild("Punch") then
                local punchTool = Player.Backpack:FindFirstChild("Punch")
                if punchTool then
                    hum:EquipTool(punchTool)
                end
            else
                attackNearby()
            end
        end
    end)
    print("[UI] Auto Kill started.")
end

local function stopAutoKill()
    if autoKillConnection then autoKillConnection:Disconnect() end
    autoKillRunning = false
    print("[UI] Auto Kill stopped.")
end

local function serverHop()
    print("[UI] Attempting server hop...")
    local placeId = game.PlaceId
    local myJobId = game.JobId
    for attempt=1,6 do
        local success, response = pcall(function()
            return HttpService:JSONDecode(game:HttpGet("https://games.roblox.com/v1/games/"..placeId.."/servers/Public?sortOrder=Desc&limit=100"))
        end)
        if not success or not response or not response.data then wait(2+attempt) continue end

        local candidates = {}
        for _, srv in pairs(response.data) do
            if srv.id == myJobId then continue end
            if srv.playing >= srv.maxPlayers then continue end
            if srv.playing < 8 then continue end
            local fill = srv.playing / srv.maxPlayers
            if fill > 0.25 and fill < 0.9 then
                table.insert(candidates, srv)
            end
        end

        if #candidates > 0 then
            local target = candidates[math.random(1, #candidates)]
            pcall(function()
                TeleportService:TeleportToPlaceInstance(placeId, target.id, Player)
            end)
            break
        else
            wait(3+attempt)
        end
    end
end

