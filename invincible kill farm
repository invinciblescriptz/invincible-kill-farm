-- Approximate "can I one-shot / few-shot" check
local function GetPlayerStatValue(plr, statNames)
    if not plr then return nil end
    if type(statNames) == "string" then statNames = {statNames} end

    for _, name in statNames do
        local val = plr:GetAttribute(name)
        if val ~= nil then return tonumber(val) end
    end

    local stats = plr:FindFirstChild("leaderstats")
    if stats then
        for _, name in statNames do
            local v = stats:FindFirstChild(name)
            if v and v:IsA("ValueBase") then return tonumber(v.Value) end
        end
    end
    return nil
end

local function GetLocalPower()
    -- Muscle Legends uses Strength + Damage stat (pets/auras)
    local strength = GetPlayerStatValue(LocalPlayer, {"Strength", "Str"}) or 1
    local dmgBonus  = GetPlayerStatValue(LocalPlayer, {"Damage", "DMG"}) or 0
    return strength + dmgBonus * 10  -- rough multiplier guess
end

local function ShouldKillPlayer(target)
    if not KillOnlyWeakerEnabled then return true end

    local myPower   = GetLocalPower()
    local theirStr  = GetPlayerStatValue(target, {"Strength", "Str"}) or 1

    -- Very rough: if your power >> their strength, assume fast kill
    return myPower > theirStr * 3
end

