local autoKillActive = false
local killConnection

local function startAutoKill()
    if autoKillActive then return end
    autoKillActive = true
    killConnection = RunService.Heartbeat:Connect(function()
        if not AutoFarm then return end
        local char = LocalPlayer.Character
        local hum = char and char:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 then return end
        if not char:FindFirstChild("Punch") then
            local tool = LocalPlayer.Backpack:FindFirstChild("Punch")
            if tool then
                Humanoid:EquipTool(tool)
            end
            return
        end
        AttackNearbyPlayers()
    end)
end

local function stopAutoKill()
    if killConnection then killConnection:Disconnect() end
    autoKillActive = false
end

