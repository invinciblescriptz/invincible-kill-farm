-- ===========================================

-- Find punch remote (multiple attempts)
local punchRemote = nil
for _, obj in ipairs(game:GetService("ReplicatedStorage"):GetDescendants()) do
    if obj:IsA("RemoteEvent") and (obj.Name:lower():find("punch") or obj.Name:lower():find("attack") or obj.Name:lower():find("hit")) then
        punchRemote = obj
        break
    end
end

