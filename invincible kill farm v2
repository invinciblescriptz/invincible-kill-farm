-- Draggable
local dragging, dragInput, dragStart, startPos
Frame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = Frame.Position
    end
end)

Frame.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)

RunService.RenderStepped:Connect(function()
    if dragging and dragInput then
        local delta = dragInput.Position - dragStart
        Frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

local function UpdateGUI()
    KillsLabel.Text = "Kills: " .. Kills
end

-- Check if player should be skipped
local function ShouldSkip(plr)
    if plr == LocalPlayer then return true end
    if table.find(WhitelistedUsers, plr.Name) then return true end
    
    -- Skip if stronger than you
    local myStrength = 0
    local theirStrength = 0
    
    pcall(function()
        myStrength = LocalPlayer.leaderstats.Strength.Value
    end)
    
    pcall(function()
        theirStrength = plr.leaderstats.Strength.Value
    end)
    
    return theirStrength > myStrength
end

-- Silent Kill All
local function SilentKillAll()
    for _, plr in ipairs(Players:GetPlayers()) do
        if not ShouldSkip(plr) and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
            local targetRoot = plr.Character.HumanoidRootPart
            local myChar = LocalPlayer.Character
            if myChar and myChar:FindFirstChild("HumanoidRootPart") then
                myChar.HumanoidRootPart.CFrame = targetRoot.CFrame * CFrame.new(0, 0, -3.5)
                
                for i = 1, 15 do
                    pcall(function()
                        if punchRemote then
                            punchRemote:FireServer()
                        end
                    end)
                    task.wait(0.025)
                end
                
                Kills = Kills + 1
                UpdateGUI()
            end
        end
    end
end

-- Server Hop
local function ServerHop()
    StatusLabel.Text = "Hopping server..."
    StatusLabel.TextColor3 = Color3.fromRGB(255, 200, 60)
    task.wait(0.7)
    
    local placeId = game.PlaceId
    local servers = {}
    
    pcall(function()
        local data = HttpService:JSONDecode(game:HttpGet("https://games.roblox.com/v1/games/" .. placeId .. "/servers/Public?sortOrder=Asc&limit=100"))
        for _, v in pairs(data.data) do
            if v.playing < v.maxPlayers and v.id ~= game.JobId then
                table.insert(servers, v.id)
            end
        end
    end)
    
    if #servers > 0 then
        TeleportService:TeleportToPlaceInstance(placeId, servers[math.random(1, #servers)], LocalPlayer)
    else
        TeleportService:Teleport(placeId, LocalPlayer)
    end
end

-- Hop on Death
if AUTO_HOP_ON_DEATH then
    LocalPlayer.CharacterAdded:Connect(function()
        task.wait(2) -- small delay after respawn
        if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
            LocalPlayer.Character.Humanoid.Died:Connect(function()
                task.wait(1.5)
                ServerHop()
            end)
        end
    end)
    
    -- Check current character
    if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
        LocalPlayer.Character.Humanoid.Died:Connect(function()
            task.wait(1.5)
            ServerHop()
        end)
    end
end

-- Main loop
task.spawn(function()
    while true do
        SilentKillAll()
        task.wait(0.55)
        
        if math.floor(tick()) % HOP_INTERVAL == 0 then
            ServerHop()
        end
    end
end)

HopButton.MouseButton1Click:Connect(ServerHop)

print("✅ ML Silent Killer loaded with whitelist + skip stronger + hop on death")
