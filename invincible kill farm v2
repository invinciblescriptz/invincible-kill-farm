local library = loadstring(game:HttpGet("https://raw.githubusercontent.com/memejames/elerium-v2-ui-library/refs/heads/main/Example%20with%20everything", true))()

-- VENTANA PRINCIPAL
local window = library:AddWindow(string.format("invincible kill farming | V2 || Made by invincible || Hello %s", game.Players.LocalPlayer.DisplayName), {
    main_color = Color3.fromRGB(0, 0, 0),
    min_size = Vector2.new(660, 890),
    can_resize = false,
})

-- Crear ScreenGui
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "KillsCounterGui"
screenGui.Parent = game.Players.LocalPlayer:WaitForChild("PlayerGui")
screenGui.ResetOnSpawn = false

-- Crear Frame draggable
local frame = Instance.new("Frame")
frame.Size = UDim2.new(0, 220, 0, 80)
frame.Position = UDim2.new(0.5, -110, 0, 10)
frame.BackgroundColor3 = Color3.new(0, 0, 0)
frame.BorderSizePixel = 0
frame.Active = true
frame.Draggable = true
frame.Parent = screenGui

-- Crear TextLabel para mostrar kills
local killsLabel = Instance.new("TextLabel")
killsLabel.Size = UDim2.new(1, -20, 0, 40)
killsLabel.Position = UDim2.new(0, 10, 0, 10)
killsLabel.BackgroundColor3 = Color3.new(0.2, 0.2, 0.2)
killsLabel.TextColor3 = Color3.new(1, 1, 1)
killsLabel.Font = Enum.Font.SourceSansBold
killsLabel.TextSize = 20
killsLabel.Text = "Kills: 0"
killsLabel.Parent = frame

-- Contador de kills
local totalKills = 0

-- Función para incrementar kills
local function incrementKills()
    totalKills = totalKills + 1
    killsLabel.Text = "Kills: " .. totalKills
end

