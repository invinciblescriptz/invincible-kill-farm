-- Server Hop
local function ServerHop()
    local placeId = game.PlaceId
    local myJobId = game.JobId
    for attempt = 1, 6 do
        local success, response = pcall(function()
            return HttpService:JSONDecode(game:HttpGet(
                "https://games.roblox.com/v1/games/" .. placeId .. "/servers/Public?sortOrder=Desc&limit=100"
            ))
        end)
        if not success or not response or not response.data then
            task.wait(2 + attempt)
            continue
        end
        local candidates = {}
        for _, srv in response.data do
            if srv.id == myJobId then continue end
            if srv.playing >= srv.maxPlayers then continue end
            if srv.playing < 8 then continue end
            local fill = srv.playing / srv.maxPlayers
            if fill > 0.25 and fill < 0.9 then
                table.insert(candidates, srv)
            end
        end
        if #candidates == 0 then
            task.wait(3 + attempt * 1.5)
            continue
        end
        local target = candidates[math.random(1, #candidates)]
        pcall(function()
            TeleportService:TeleportToPlaceInstance(placeId, target.id, LocalPlayer)
        end)
        task.wait(5 + attempt * 2)
    end
end

-- Main Loop
RunService.Heartbeat:Connect(function()
    if AutoServerHopEnabled and (os.clock() - LastServerHop) >= ServerHopInterval then
        LastServerHop = os.clock()
        task.spawn(ServerHop)
    end
    if AutoBigHitboxEnabled and math.floor(os.clock() * 10) % 3 == 0 then
        setBigHitbox()
    end

    UpdateAll()
    if not AutoFarmEnabled or not Character or not Humanoid or Humanoid.Health <= 0 then
        return
    end

    if not Punch then
        local tool = LocalPlayer.Backpack:FindFirstChild("Punch")
        if tool then Humanoid:EquipTool(tool) end
        return
    end

    if (os.clock() - LastAttack) < 0.08 then return end
    LastAttack = os.clock()

    local attackTime = Punch:FindFirstChild("attackTime")
    if attackTime then attackTime.Value = 0 end
    Punch:Activate()

    for _, other in Players:GetPlayers() do
        if other == LocalPlayer then continue end
        if not ShouldKillPlayer(other) then continue end

        local char = other.Character
        if not char then continue end
        local hum = char:FindFirstChildOfClass("Humanoid")
        local head = char:FindFirstChild("Head")
        local root = char:FindFirstChild("HumanoidRootPart")

        if hum and head and root and hum.Health > 0 and Hand then
            local wasAnchored = root.Anchored
            root.Anchored = true
            firetouchinterest(head, Hand, 0)
            task.wait()
            firetouchinterest(head, Hand, 1)
            root.Anchored = wasAnchored
        end
    end
end)

