-- Draggable
local dragging, dragStart, startPos
Frame.InputBegan:Connect(function(inp)
    if inp.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = inp.Position
        startPos = Frame.Position
    end
end)
Frame.InputChanged:Connect(function(inp)
    if inp.UserInputType == Enum.UserInputType.MouseMovement then
        dragInput = inp
    end
end)
RunService.RenderStepped:Connect(function()
    if dragging and dragInput then
        local delta = dragInput.Position - dragStart
        Frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

local function updateGUI()
    SessionLabel.Text = "Session Kills: " .. SessionKills
    TotalLabel.Text = "Total Kills: " .. TotalKills
end

local function shouldSkip(plr)
    if plr == LocalPlayer then return true end
    if table.find(WhitelistedUsers, plr.Name) then return true end
    local myStr = 0
    local theirStr = 0
    pcall(function() myStr = LocalPlayer.leaderstats.Strength.Value end)
    pcall(function() theirStr = plr.leaderstats.Strength.Value end)
    return theirStr > myStr + 8000
end

-- Silent Remote Kill (no teleport)
local function killAll()
    if not punchRemote then return end
    for _, plr in ipairs(Players:GetPlayers()) do
        if not shouldSkip(plr) and plr.Character and plr.Character:FindFirstChild("Humanoid") then
            for i = 1, 22 do
                pcall(function()
                    punchRemote:FireServer()
                end)
                task.wait(0.025)
            end
            SessionKills += 1
            TotalKills += 1
            updateGUI()
        end
    end
end

-- Improved Server Hop
local function serverHop()
    Status.Text = "Hopping server..."
    Status.TextColor3 = Color3.fromRGB(255, 200, 50)
    
    task.wait(0.8)
    
    local placeId = game.PlaceId
    local servers = {}
    
    -- Main attempt
    pcall(function()
        local resp = game:HttpGet("https://games.roblox.com/v1/games/"..placeId.."/servers/Public?sortOrder=Asc&limit=100")
        local data = HttpService:JSONDecode(resp)
        for _, v in ipairs(data.data or {}) do
            if v.playing and v.maxPlayers and v.playing < v.maxPlayers and v.id ~= game.JobId then
                table.insert(servers, v.id)
            end
        end
    end)
    
    -- Fallback
    if #servers == 0 then
        pcall(function()
            local resp = game:HttpGet("https://games.roblox.com/v1/games/"..placeId.."/servers/Public?sortOrder=Desc&limit=50")
            local data = HttpService:JSONDecode(resp)
            for _, v in ipairs(data.data or {}) do
                if v.playing < v.maxPlayers and v.id ~= game.JobId then
                    table.insert(servers, v.id)
                end
            end
        end)
    end
    
    if #servers > 0 then
        local chosen = servers[math.random(#servers)]
        TeleportService:TeleportToPlaceInstance(placeId, chosen, LocalPlayer)
    else
        TeleportService:Teleport(placeId, LocalPlayer)
    end
end

-- Hop on death
if AUTO_HOP_ON_DEATH then
    LocalPlayer.CharacterAdded:Connect(function(char)
        task.wait(2)
        local hum = char:FindFirstChild("Humanoid")
        if hum then
            hum.Died:Connect(function()
                task.wait(1.5)
                serverHop()
            end)
        end
    end)
    
    if LocalPlayer.Character then
        local hum = LocalPlayer.Character:FindFirstChild("Humanoid")
        if hum then
            hum.Died:Connect(function()
                task.wait(1.5)
                serverHop()
            end)
        end
    end
end

-- Main loop
task.spawn(function()
    while true do
        killAll()
        task.wait(0.6)
        
        if math.floor(tick()) % HOP_INTERVAL == 0 then
            serverHop()
        end
    end
end)

HopBtn.MouseButton1Click:Connect(serverHop)

print("✅ Custom ML Killer loaded - No teleport version")
updateGUI()
